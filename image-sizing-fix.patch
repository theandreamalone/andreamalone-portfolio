@@ -168,27 +168,32 @@
   margin-bottom: 10vh;
 }
 
-/* ---- Media sizing caps (2026-07-20 bug pass) ----
-   Tall portrait screenshots (phone frames) were rendering at full column
-   width → taller than the viewport, pushing carousel pagination off-screen
-   and dwarfing prose. Cap heights; let width follow. */
+/* ---- Media sizing caps (2026-07-20 bug pass; revised 2026-07-21) ----
+   Images are MIXED aspect ratios: wide desktop screenshots AND tall phone
+   frames in the same carousels. Capping by height alone let tall frames
+   dominate and left wide shots floating tiny in the column. Cap BOTH height
+   and width, center, and let each image keep its own shape ("natural, capped").
+   Screenshots render square-cornered — rounding a screenshot-of-a-screen clips
+   real UI corners. */
 
 /* Inline MDX images + single media */
 .case-study-body img {
   max-height: 72vh;
   width: auto;
-  max-width: 100%;
+  max-width: min(100%, 900px);
   margin-inline: auto;
   object-fit: contain;
+  border-radius: 0;
 }
 
 /* Carousel slides */
 .cs-carousel img {
-  max-height: 60vh;
+  max-height: 68vh;
   width: auto;
-  max-width: 100%;
+  max-width: min(100%, 900px);
   margin: 0 auto;
   object-fit: contain;
+  border-radius: 0;
 }
 .cs-carousel .cs-media-expand { display: flex; justify-content: center; }
 
